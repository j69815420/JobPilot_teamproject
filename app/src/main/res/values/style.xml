<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- BottomSheetDialog용 커스텀 테마 -->
    <style name="BottomSheetDialogTheme" parent="Theme.Design.Light.BottomSheetDialog">
        <!-- 배경 둥근 모서리 적용 -->
        <item name="bottomSheetStyle">@style/CustomBottomSheetStyle</item>
    </style>

    <!-- BottomSheet 내부 스타일 (둥근 모서리) -->
    <style name="CustomBottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="shapeAppearanceOverlay">@style/BottomSheetShape</item>
    </style>

    <!-- 모서리 20dp 둥글게 -->
    <style name="BottomSheetShape" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>

<!--달력 텍스트 스타일-->
    <style name="CalendarTextStyle">
        <item name="android:textColor">#333333</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- 요일 텍스트 스타일 -->
    <style name="CalendarWeekdayText">
        <item name="android:textColor">#FF0000</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">@font/bmjua</item>
    </style>

    <!-- 날짜 텍스트 스타일 -->
    <style name="CalendarDateText">
        <item name="android:textColor">#333333</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">@font/bmjua</item>
    </style>

    <style name="CustomDateText" parent="TextAppearance.AppCompat.Small">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#000000</item>
    </style>

    <style name="CustomWeekDayText" parent="TextAppearance.AppCompat.Small">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">#834EE3</item>
    </style>

    <style name="MyInfoInterestButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">6dp</item>
        <item name="android:background">@drawable/interest_unselected</item>
        <item name="android:textColor">#000000</item>
        <item name="android:textSize">15sp</item>
        <item name="android:gravity">center_vertical|start</item>
        <item name="android:paddingStart">12dp</item>
    </style>


    <!--관심분야버튼 스타일-->
    <style name="InterestButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginHorizontal">5dp</item>
        <item name="android:paddingVertical">10dp</item>
        <item name="android:textColor">#000000</item>
        <item name="android:background">@drawable/bg_interest_button</item>
    </style>

    <style name="InterestButtonSingle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingVertical">10dp</item>
        <item name="android:layout_marginBottom">10dp</item>
        <item name="android:textColor">#000000</item>
        <item name="android:background">@drawable/bg_interest_button</item>
    </style>

    <style name="BottomNavText" parent="TextAppearance.MaterialComponents.Caption">
        <item name="fontFamily">@font/bmjua</item>
        <item name="android:textSize">12sp</item>
    </style>



</resources>
