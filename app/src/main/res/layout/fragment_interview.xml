<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#5141A1">

    <!-- 스크롤 영역 -->
    <ScrollView
        android:id="@+id/scrollArea"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/buttonContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal">


        </LinearLayout>
    </ScrollView>

    <!-- 버튼 묶음  -->
    <LinearLayout
        android:id="@+id/buttonContainer"
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_button_container"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.7">

        <!-- 제목 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI 면접 코치"
            android:textSize="30dp"
            style="@style/MyFontStyle"
            android:paddingBottom="24dp"
            android:paddingLeft="20dp"
            android:gravity="center" />

        <!-- AI 실전 모드 버튼 -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnLiveMode"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:text="AI 실전 모드"
            style="@style/MyFontStyle"
            android:textSize="40sp"
            android:background="@drawable/rec_livemode"
            android:backgroundTint="@null"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="24dp"
            android:layout_marginTop="10dp"/>

        <!-- 가로 버튼 2개 -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:weightSum="2">


            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnPracticeMode"
                style="@style/MyFontStyle"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_marginTop="5dp"
                android:layout_marginEnd="8dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/rec_practicemode"
                android:backgroundTint="@null"
                android:gravity="center"
                android:text="텍스트\n모드"

                android:textColor="#FFFFFF"
                android:textSize="40sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnFeedBack"
                android:layout_width="0dp"
                android:layout_height="150dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:layout_marginTop="5dp"
                android:text="피드백"
                style="@style/MyFontStyle"
                android:textSize="40sp"
                android:background="@drawable/rec_feedback"
                android:backgroundTint="@null"
                android:textColor="#FFFFFF"
                android:layout_marginStart="8dp"
              />

        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
