<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="20dp">

    <!-- 상단 타이틀 -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="관심분야 선택"
        android:textSize="21sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="#000000"
        android:layout_marginTop="5dp"
        android:layout_marginBottom="10dp" />

    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="* 최대 3가지 분야 선택이 가능 합니다"
        android:textSize="12sp"
        android:textColor="#808080"
        android:gravity="start"
        android:layout_marginBottom="15dp" />

    <!-- 스크롤 영역 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/layout_interest_buttons"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- 1 -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginBottom="10dp">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_frontend"
                    style="@style/InterestButton"
                    android:layout_width="166dp"
                    android:layout_height="40dp"
                    android:text="프론트엔드"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_backend"
                    style="@style/InterestButton"
                    android:layout_width="166dp"
                    android:layout_height="40dp"
                    android:text="백엔드"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp" />
            </LinearLayout>

            <!-- 2 -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginBottom="10dp">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_fullstack"
                    style="@style/InterestButton"
                    android:layout_width="166dp"
                    android:layout_height="40dp"
                    android:text="풀스택"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_android"
                    style="@style/InterestButton"
                    android:layout_width="166dp"
                    android:layout_height="40dp"
                    android:text="안드로이드"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp" />
            </LinearLayout>

            <!-- 3 -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginBottom="10dp">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_ios"
                    style="@style/InterestButton"
                    android:layout_width="166dp"
                    android:layout_height="40dp"
                    android:text="IOS"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_cross"
                    style="@style/InterestButton"
                    android:layout_width="166dp"
                    android:layout_height="40dp"
                    android:text="크로스플랫폼"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp" />
            </LinearLayout>

            <!-- 4 -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginBottom="10dp">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_data"
                    style="@style/InterestButton"
                    android:layout_width="166dp"
                    android:layout_height="40dp"
                    android:text="데이터 분석"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_ml"
                    style="@style/InterestButton"
                    android:layout_width="166dp"
                    android:layout_height="40dp"
                    android:text="머신러닝/딥러닝"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp" />
            </LinearLayout>

            <!-- 5 -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_cloud"
                style="@style/InterestButtonSingle"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="클라우드(AWS,Azure,GCP)"
                android:textStyle="bold"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="10dp" />

            <!-- 6 -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_ai"
                    style="@style/InterestButton"
                    android:layout_width="166dp"
                    android:layout_height="40dp"
                    android:text="AI 서비스 개발"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_devops"
                    style="@style/InterestButton"
                    android:layout_width="166dp"
                    android:layout_height="40dp"
                    android:text="DevOps/MLOps"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp" />
            </LinearLayout>

            <!-- 7 -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginBottom="10dp">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_security"
                    style="@style/InterestButton"
                    android:layout_width="166dp"
                    android:layout_height="40dp"
                    android:text="보안/네트워크"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_game_client"
                    style="@style/InterestButton"
                    android:layout_width="166dp"
                    android:layout_height="40dp"
                    android:text="게임 클라이언트"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp" />
            </LinearLayout>

            <!-- 8 -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginBottom="10dp">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_game_server"
                    style="@style/InterestButton"
                    android:layout_width="166dp"
                    android:layout_height="40dp"
                    android:text="게임 서버"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_arvr"
                    style="@style/InterestButton"
                    android:layout_width="166dp"
                    android:layout_height="40dp"
                    android:text="AR/VR"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp" />
            </LinearLayout>

            <!-- 9 -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_fw"
                style="@style/InterestButtonSingle"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:text="마이크로컨트롤러/펌웨어"
                android:textStyle="bold"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:layout_marginBottom="10dp" />

            <!-- 10 -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginBottom="10dp">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_iot"
                    style="@style/InterestButton"
                    android:layout_width="166dp"
                    android:layout_height="40dp"
                    android:text="IoT 플랫폼 개발"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_blockchain"
                    style="@style/InterestButton"
                    android:layout_width="166dp"
                    android:layout_height="40dp"
                    android:text="블록체인"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp" />
            </LinearLayout>

            <!-- 11 -->
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginBottom="10dp">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_robotics"
                    style="@style/InterestButton"
                    android:layout_width="166dp"
                    android:layout_height="40dp"
                    android:text="로보틱스"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_opensource"
                    style="@style/InterestButton"
                    android:layout_width="166dp"
                    android:layout_height="40dp"
                    android:text="오픈소스 기여"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- 선택 완료 버튼 -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btn_complete"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="선택 완료"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:backgroundTint="@null"
        android:background="@drawable/bg_all_purple"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        android:paddingVertical="10dp" />

</LinearLayout>
