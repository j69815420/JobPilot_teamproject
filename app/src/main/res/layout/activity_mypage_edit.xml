<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:padding="20dp"
    tools:context=".MyInfoEditActivity">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- 상단바 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingBottom="10dp">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnBack"
                android:layout_width="20dp"
                android:layout_height="wrap_content"
                android:background="@null"
                android:text="&lt;"
                android:textSize="18sp"
                android:textColor="#333" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="내 정보 변경"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- 아이디 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="아이디"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="10dp" />

        <EditText
            android:id="@+id/editId"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@drawable/et_id_ligtgray"
            android:padding="8dp"
            android:textColor="#333"
            android:inputType="text" />

        <!-- 이메일 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/black"
            android:text="이메일"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="15dp" />

        <EditText
            android:id="@+id/editEmail"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@drawable/et_id_ligtgray"
            android:padding="8dp"
            android:inputType="textEmailAddress"
            android:textColor="#333" />

        <EditText
            android:id="@+id/editCurrentPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="현재 비밀번호"
            android:inputType="textPassword"/>


        <!-- 생년월일 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="생년월일"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="15dp" />

        <EditText
            android:id="@+id/editBirth"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:gravity="center_vertical"
            android:background="@drawable/et_id_ligtgray"
            android:paddingStart="10dp"
            android:textColor="#666" />

        <!-- 관심분야 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/black"
            android:text="관심분야"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="20dp" />


        <!-- 선택된 관심분야 표시용 컨테이너 -->
        <LinearLayout
            android:id="@+id/selected_fields_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp"
            android:gravity="start"
            android:padding="4dp">
        </LinearLayout>

        <!-- 관심분야 버튼들 (세로 나열, 회색선 제거) -->
        <LinearLayout
            android:id="@+id/linearInterests"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:divider="@null">

            <androidx.appcompat.widget.AppCompatButton android:text="프론트엔드" style="@style/MyInfoInterestButton" />
            <androidx.appcompat.widget.AppCompatButton android:text="백엔드" style="@style/MyInfoInterestButton" />
            <androidx.appcompat.widget.AppCompatButton android:text="풀스택" style="@style/MyInfoInterestButton" />
            <androidx.appcompat.widget.AppCompatButton android:text="안드로이드" style="@style/MyInfoInterestButton" />
            <androidx.appcompat.widget.AppCompatButton android:text="iOS" style="@style/MyInfoInterestButton" />
            <androidx.appcompat.widget.AppCompatButton android:text="크로스플랫폼" style="@style/MyInfoInterestButton" />
            <androidx.appcompat.widget.AppCompatButton android:text="데이터 분석" style="@style/MyInfoInterestButton" />
            <androidx.appcompat.widget.AppCompatButton android:text="머신러닝/딥러닝" style="@style/MyInfoInterestButton" />
            <androidx.appcompat.widget.AppCompatButton android:text="AI 서비스 개발" style="@style/MyInfoInterestButton" />
            <androidx.appcompat.widget.AppCompatButton android:text="클라우드(AWS, Azure, GCP)" style="@style/MyInfoInterestButton" />
            <androidx.appcompat.widget.AppCompatButton android:text="DevOps/MLOps" style="@style/MyInfoInterestButton" />
            <androidx.appcompat.widget.AppCompatButton android:text="보안/네트워크" style="@style/MyInfoInterestButton" />
            <androidx.appcompat.widget.AppCompatButton android:text="게임 클라이언트" style="@style/MyInfoInterestButton" />
            <androidx.appcompat.widget.AppCompatButton android:text="게임 서버" style="@style/MyInfoInterestButton" />
            <androidx.appcompat.widget.AppCompatButton android:text="AR/VR" style="@style/MyInfoInterestButton" />
            <androidx.appcompat.widget.AppCompatButton android:text="마이크로컨트롤러/펌웨어" style="@style/MyInfoInterestButton" />
            <androidx.appcompat.widget.AppCompatButton android:text="IoT 플랫폼 개발" style="@style/MyInfoInterestButton" />
            <androidx.appcompat.widget.AppCompatButton android:text="블록체인" style="@style/MyInfoInterestButton" />
            <androidx.appcompat.widget.AppCompatButton android:text="로보틱스" style="@style/MyInfoInterestButton" />
            <androidx.appcompat.widget.AppCompatButton android:text="오픈소스 기여" style="@style/MyInfoInterestButton" />
        </LinearLayout>

        <!-- 정보 변경 버튼 -->
        <Button
            android:id="@+id/btnUpdateInfo"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="정보 변경"
            android:textColor="#FFFFFF"
            android:backgroundTint="#7B68EE"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="20dp"
            android:layout_gravity="center" />

    </LinearLayout>
</ScrollView>
