<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="20dp"
    android:layout_width="match_parent"
    android:layout_height="250dp"
    android:background="@drawable/bg_bottom_sheet">

    <TextView
        android:id="@+id/bottom_sheet_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="로그아웃"
        android:textColor="#6C57D3"
        android:textSize="28sp"
        android:textStyle="bold"
        android:gravity="center"/>

    <TextView
        android:id="@+id/bottom_sheet_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="20dp"
        android:paddingBottom="40dp"

        android:text="현재 세션에서 로그아웃됩니다. 계속하시겠습니까?"
        android:textColor="#777777"
        android:textSize="15sp"
        android:gravity="center"
        android:layout_marginTop="1dp"
        android:layout_marginBottom="2dp"/>

    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingHorizontal="20dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/bottom_sheet_cancel"
            android:layout_width="144dp"
            android:layout_height="45dp"
            android:text="취소"
            android:textStyle="bold"
            android:textSize="16dp"
            android:textColor="#FFFFFF"
            android:backgroundTint="@null"

            android:background="@drawable/bg_gray_button"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/bottom_sheet_confirm"
            android:layout_width="144dp"
            android:layout_height="45dp"
            android:text="로그아웃"
            android:textStyle="bold"
            android:textSize="16dp"
            android:backgroundTint="@null"
            android:textColor="#FFFFFF"
            android:layout_marginStart="20dp"
            android:background="@drawable/bg_purple_button"/>
    </LinearLayout>
</LinearLayout>
