<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- 상단 보라색 직사각형 + 수평 텍스트 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="98dp"
            android:background="@color/dpurple"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="24dp"
            android:paddingTop="35dp"
            android:paddingEnd="10dp"
            android:paddingBottom="0dp">

            <TextView
                style="@style/MyFontStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="자소서"
                android:textColor="@color/white"
                android:textSize="28sp"/>

            <TextView
                style="@style/MyFontStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="     AI 분석 &amp; 피드백"
                android:textColor="@color/white"
                android:textSize="18sp"/>
        </LinearLayout>

        <!-- 자소서 내용 보라색 박스 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="429dp"
            android:layout_margin="16dp"
            android:background="@drawable/bg_purple_resumebox"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent">

            <TextView
                android:id="@+id/tvResumeContent"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scrollbars="vertical"
                android:text="자소서 내용"
                android:textColor="#000000"
                android:textSize="16sp" />
            </androidx.core.widget.NestedScrollView>
        </LinearLayout>


        <!-- AI 피드백 회색 박스 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_margin="16dp"
            android:background="@drawable/bg_gray_resumebox"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/tvAIResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="AI 분석 피드백"
                    android:textColor="#000000"
                    android:textSize="16sp"/>

            </androidx.core.widget.NestedScrollView>

        </LinearLayout>

        <!-- 수정하기 / 삭제하기 버튼 2개 가로 배치 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:weightSum="2"
            android:spacing="8dp">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnEditResume"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="수정하기"
                android:textStyle="bold"
                android:background="@drawable/bg_all_purple"
                android:textColor="@android:color/white"
                android:layout_marginEnd="8dp"/>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnDeleteResume"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="삭제하기"
                android:textStyle="bold"
                android:background="@drawable/bg_all_purple"
                android:textColor="@android:color/white"
                android:layout_marginStart="8dp"/>
        </LinearLayout>


    </LinearLayout>
</ScrollView>
