<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"

    android:background="@color/white">

    <!-- 상단 바 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&lt;"
            android:textStyle="bold"
            android:textColor="#7357FF"
            android:textSize="24sp"
            android:background="@android:color/transparent"
            android:layout_alignParentStart="true"
            android:padding="8dp"/>

        <TextView
            android:id="@+id/tv_score_big"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="30dp"
            android:text="91"
            android:textSize="96dp"
            android:textColor="#5035D9"
            android:fontFamily="@font/vidaloka"
            android:layout_centerHorizontal="true"/>

        <TextView
            android:id="@+id/tv_score_small"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="/100"
            android:fontFamily="@font/vidaloka"
            android:textSize="32dp"
            android:textColor="#5035D9"
            android:layout_toEndOf="@id/tv_score_big"
            android:layout_alignBottom="@id/tv_score_big"/>
    </RelativeLayout>

    <!-- 버튼 영역 -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        android:layout_gravity="center"
        android:weightSum="4">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_answer_content"
            android:layout_width="80dp"
            android:layout_height="38dp"
            android:text="답변내용"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:background="@drawable/bg_button_unselected"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_voice_analysis"
            android:layout_width="80dp"
            android:layout_height="38dp"
            android:text="음성분석"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:layout_marginStart="20dp"
            android:background="@drawable/bg_button_unselected"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_ai_analysis"
            android:layout_width="80dp"
            android:layout_height="38dp"
            android:text="AI분석"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:layout_marginStart="20dp"
            android:background="@drawable/bg_button_unselected"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_total_review"
            android:layout_width="80dp"
            android:layout_height="38dp"
            android:text="종합평가"
            android:textColor="#ffff"
            android:textStyle="bold"
            android:layout_marginStart="20dp"
            android:background="@drawable/bg_button_selected"/>
    </LinearLayout>

    <!-- 내용 박스 -->
    <TextView
        android:id="@+id/tv_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:text="답변내용 피드백이 여기에 표시됩니다."
        android:background="@drawable/bg_content_box"
        android:textColor="#4E4E4E"/>
</LinearLayout>